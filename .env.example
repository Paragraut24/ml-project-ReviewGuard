# ReviewGuard Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================
# Model Configuration
# ============================================

# HuggingFace Model Configuration
# For private models, set both MODEL_ID and TOKEN
# For public models, TOKEN is optional
HF_MODEL_ID=your-username/your-model-name
HF_TOKEN=hf_your_token_here_optional_for_public_models

# Model Backend Selection
# Options: auto, local, pipeline, hf_api
# - auto: Automatically selects best available backend
# - local: Uses local model weights from ./bert_model/
# - pipeline: Downloads model from HuggingFace and runs locally
# - hf_api: Uses HuggingFace Inference API (recommended for deployment)
MODEL_BACKEND=auto

# ============================================
# Flask Configuration
# ============================================

# Flask Debug Mode (set to 0 in production)
FLASK_DEBUG=0

# Flask Secret Key (generate a random string)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-this

# Port (default: 5000)
PORT=5000

# ============================================
# Deployment Configuration
# ============================================

# Set to 1 if deploying to Render
RENDER=0

# Set to 1 if deploying to Railway
RAILWAY=0

# Set to 1 if deploying to Heroku
HEROKU=0

# ============================================
# Optional: Rate Limiting
# ============================================

# Maximum requests per minute per IP
RATE_LIMIT_PER_MINUTE=60

# Maximum requests per hour per IP
RATE_LIMIT_PER_HOUR=1000

# ============================================
# Optional: Analytics
# ============================================

# Google Analytics ID (optional)
GA_TRACKING_ID=

# ============================================
# Optional: Error Tracking
# ============================================

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# ============================================
# SECURITY NOTES
# ============================================

# 1. NEVER commit .env file to Git
# 2. Use strong, random values for SECRET_KEY
# 3. Keep HF_TOKEN private if using private models
# 4. Rotate secrets regularly
# 5. Use different secrets for development and production
# 6. Set FLASK_DEBUG=0 in production

# ============================================
# DEPLOYMENT CHECKLIST
# ============================================

# Before deploying:
# ✓ Set all required environment variables on your hosting platform
# ✓ Set FLASK_DEBUG=0
# ✓ Generate a strong SECRET_KEY
# ✓ Configure HF_MODEL_ID and HF_TOKEN if using private models
# ✓ Test the application locally first
# ✓ Enable HTTPS on your hosting platform
# ✓ Set up monitoring and error tracking

